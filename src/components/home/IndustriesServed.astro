---
import TestimonialCard from '../ui/TestimonialCard.astro';

import testimonial1Img from '@assets/photo-1494790108377-be9c29b29330.jpg';

const testimonials= [
  {
    quote: "He leads strategic projects that connect talent, organizations, and growth opportunities. His approach combines entrepreneurial vision with HR expertise to support companies through development and transformation.",
    name: "Luca Ittiresu",
    role: "Founder & CEO",
    image: testimonial1Img,
    ringColor: "ring-teal-200"
  }
];

interface Industry {
  title: string;
  description: string;
  iconGradient: string;
  iconPath: string;
  features: string[];
}

const industries: Industry[] = [
  {
    title: "Recruitment",
    description: "Professional recruitment connecting top talent with leading companies through precise, efficient hiring solutions.",
    iconGradient: "from-blue-500 to-blue-600",
    iconPath: "M10.5 4a6.5 6.5 0 1 0 4.1 11.6l4.7 4.7a1 1 0 0 0 1.4-1.4l-4.7-4.7A6.5 6.5 0 0 0 10.5 4zm0 2a4.5 4.5 0 1 1 0 9a4.5 4.5 0 0 1 0-9z",
    features: ["Talent expertise", "Speed & efficiency", "Trusted partnerships"]
  },
  {
    title: "Human resources",
    description: "Strategic human resources solutions that optimize talent, improve performance, and support sustainable business growth.",
    iconGradient: "from-teal-500 to-teal-600",
    iconPath: "M12 5.5    a2.5 2.5 0 1 0 0.001 0    M7 18    c0-3 2.5-5 5-5    s5 2 5 5    M5.5 8.2    a1.8 1.8 0 1 0 0.001 0    M2.5 18    c0-2 1.8-3.5 3-3.5    M18.5 8.2 a1.8 1.8 0 1 0 0.001 0    M21.5 18    c0-2-1.8-3.5-3-3.5",
    features: ["People-Centric approach", "Operational excellence", "Strategic workforce management"]
  },
  {
    title: "Mergers & acquisitions",
    description: "Strategic mergers and acquisitions advisory driving value creation, seamless integration, and sustainable business growth.",
    iconGradient: "from-blue-600 to-teal-600",
    iconPath: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    features: ["Strategic value creation", "Financial & market expertise", "Seamless deal execution"]
  }
];

const checkmarkPath = "M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z";
---

<section class="py-24 bg-linear-to-b from-slate-50 to-white" id="about-us">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        About Us
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Discovering <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Ichnos Consultancy LTD</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Born in Malta in 2026<br />
        Where Talent Meets Opportunity.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {industries.map((industry) => (
        <div class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-slate-100">
          <div class={`w-16 h-16 rounded-xl bg-linear-to-br ${industry.iconGradient} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform`}>
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={industry.iconPath} />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-3">{industry.title}</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            {industry.description}
          </p>
          <ul class="space-y-2 text-sm text-slate-600">
            {industry.features.map((feature) => (
              <li class="flex items-center">
                <svg class="w-4 h-4 text-teal-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d={checkmarkPath} clip-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <div class="grid grid-cols-1 gap-8">
        {testimonials.map((testimonial) => (
          <TestimonialCard testimonial={testimonial} variant="home" />
        ))}
      </div>
    </div>
</section>
