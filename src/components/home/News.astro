---
import { Image } from 'astro:assets';

import discoveryImg from '@assets/photo-1454165804606-c3d57bc86b40.jpg';
import implementationImg from '@assets/photo-1522071820081-009f0129c71c.jpg';
import optimizationImg from '@assets/photo-1551288049-bebda4e38f71.jpg';
import supportGrowthImg from '@assets/photo-1552664730-d307ca884978.jpg';

const items = [
  {
    number: 1,
    title: "Discovery & Planning",
    description: "We analyze your current operations, identify pain points, and design a customized solution that aligns with your business goals.",
    image: discoveryImg,
    alt: "Business planning and strategy",
    hoverBorder: "hover:border-blue-500",
    gradient: "from-blue-600/90",
    textColor: "text-blue-600"
  },
  {
    number: 2,
    title: "Implementation",
    description: "Our expert team sets up your infrastructure, integrates systems, and ensures seamless onboarding with minimal disruption.",
    image: implementationImg,
    alt: "Team collaboration and implementation",
    hoverBorder: "hover:border-teal-500",
    gradient: "from-teal-600/90",
    textColor: "text-teal-700"
  },
  {
    number: 3,
    title: "Optimization",
    description: "Continuous monitoring and data-driven improvements ensure your operations become more efficient and cost-effective over time.",
    image: optimizationImg,
    alt: "Data analytics and optimization",
    hoverBorder: "hover:border-blue-500",
    gradient: "from-blue-600/90",
    textColor: "text-blue-600"
  },
  {
    number: 4,
    title: "Support & Growth",
    description: "Dedicated account management and 24/7 support help you scale operations and adapt to changing market demands.",
    image: supportGrowthImg,
    alt: "Customer support and growth",
    hoverBorder: "hover:border-teal-500",
    gradient: "from-teal-600/90",
    textColor: "text-teal-700"
  }
];

const arrowPath = "M9 5l7 7-7 7";
---

<section class="py-24 bg-white" id="news">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-teal-100 text-teal-800 text-sm font-semibold rounded-full">
        News
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        All you need <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">to know</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Latest updates, insights, and stories from across the industry, all in one place.
      </p>
    </div>

    <div class="relative">
      <!-- Connection Line (hidden on mobile) -->
      <div class="hidden lg:block absolute top-24 left-0 right-0 h-0.5 bg-linear-to-r from-blue-200 via-teal-200 to-blue-200"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        {items.map((item) => (
          <div class="relative h-full">
            <div class={`bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all border-2 border-slate-100 ${item.hoverBorder} relative z-10 flex flex-col h-full`}>
              <div class="relative h-48 overflow-hidden">
                <Image 
                  src={item.image}
                  alt={item.alt}
                  class="w-full h-full object-cover"
                  width={800}
                  height={400}
                />
                <div class={`absolute inset-0 bg-linear-to-t ${item.gradient} to-transparent`}></div>
                <div class={`absolute top-4 right-4 w-12 h-12 rounded-full bg-white/90 backdrop-blur-sm flex items-center justify-center ${item.textColor} font-bold text-xl shadow-lg`}>
                  {item.number}
                </div>
              </div>
              <div class="p-8 flex flex-col flex-1">
                <h3 class="text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
                <p class="text-slate-600 leading-relaxed flex-1">
                  {item.description}
                </p>
                <div class={`mt-6 flex items-center text-sm ${item.textColor} font-semibold`}>
                  Learn more
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={arrowPath} />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


