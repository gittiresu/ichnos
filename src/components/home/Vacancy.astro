---
import VacancyShowcase from '../react/VacancyShowcase';
---

<section class="py-24 bg-slate-50" id="vacancy">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Vacancy
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Find our <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">open positions</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Explore current openings and discover opportunities to grow your career with us.
        Find the role that matches your skills and ambitions.
      </p>
    </div>

    <VacancyShowcase client:load />
    
  </div>
</section>

